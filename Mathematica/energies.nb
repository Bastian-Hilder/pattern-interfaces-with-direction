 CellChangeTimes->{{3.982928190405458*^9, 
  3.9829281941201677`*^9}},ExpressionUUID->"3e4005c1-7916-4d50-a1ea-\
61bdcd18fb57"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"F", "[", 
    RowBox[{"A1_", ",", "A2_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"\[Mu]0", "/", "2"}], ")"}], "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"A1", "^", "2"}], "+", 
       RowBox[{"A2", "^", "2"}]}], ")"}]}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"K0", "/", "4"}], ")"}], "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"A1", "^", "4"}], "+", 
       RowBox[{"A2", "^", "4"}]}], ")"}]}], "+", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"K1", "/", "2"}], ")"}], "*", 
     RowBox[{"A1", "^", "2"}], "*", 
     RowBox[{"A2", "^", "2"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Aroll1", "=", 
   RowBox[{"Sqrt", "[", 
    RowBox[{"\[Mu]0", "/", 
     RowBox[{"-", "K0"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Aroll2", "=", "0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Asquare1", "=", 
   RowBox[{"Sqrt", "[", 
    RowBox[{
     RowBox[{"-", "\[Mu]0"}], "/", 
     RowBox[{"(", 
      RowBox[{"K0", "+", "K1"}], ")"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Asquare2", "=", 
   RowBox[{"Sqrt", "[", 
    RowBox[{
     RowBox[{"-", "\[Mu]0"}], "/", 
     RowBox[{"(", 
      RowBox[{"K0", "+", "K1"}], ")"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"F", "[", 
   RowBox[{"Aroll1", ",", "Aroll2"}], "]"}], "//", 
  "FullSimplify"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"F", "[", 
   RowBox[{"Asquare1", ",", "Asquare2"}], "]"}], "//", 
  "FullSimplify"}]}], "Input",
