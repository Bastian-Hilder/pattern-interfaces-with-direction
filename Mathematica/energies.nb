        RowBox[{"\[Beta]2", "^", "2"}], "/", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"K0", "-", "K2"}], ")"}], "^", "2"}]}]}]}], ",", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[Beta]2", ">", "0"}], ",", 
        RowBox[{"K0", "<", "0"}], ",", 
        RowBox[{"K2", "<", "0"}], ",", 
        RowBox[{"K2", ">", "K0"}]}], "}"}]}]}], "]"}], "\[IndentingNewLine]", 
   
   RowBox[{"(*", " ", 
    RowBox[{"\[Mu]Roll", "[", 
     RowBox[{"[", "3", "]"}], "]"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{
     RowBox[{
      FractionBox[
       RowBox[{"K0", " ", 
        SuperscriptBox["\[Beta]2", "2"]}], 
       RowBox[{
        RowBox[{
         RowBox[{"-", "2"}], " ", 
         SqrtBox["2"], " ", 
         SqrtBox[
          RowBox[{"K0", " ", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"K0", "+", "K2"}], ")"}], "3"]}]]}], "+", 
        RowBox[{"2", " ", "K0", " ", 
         RowBox[{"(", 
          RowBox[{"K0", "+", 
           RowBox[{"3", " ", "K2"}]}], ")"}]}]}]], ">=", 
      RowBox[{
       RowBox[{"-", "K0"}], "*", 
       RowBox[{
        RowBox[{"\[Beta]2", "^", "2"}], "/", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"K0", "-", "K2"}], ")"}], "^", "2"}]}]}]}], ",", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[Beta]2", ">", "0"}], ",", 
        RowBox[{"K0", "<", "0"}], ",", 
        RowBox[{"K2", "<", "0"}], ",", 
        RowBox[{"K2", ">", "K0"}]}], "}"}]}]}], "]"}]}]}]], "Input",
