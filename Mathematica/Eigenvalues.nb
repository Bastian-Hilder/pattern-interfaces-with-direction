Cell[BoxData[{
 RowBox[{
  RowBox[{"vecField", "[", 
   RowBox[{"x_", ",", "y_", ",", "z_"}], "]"}], ":=", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"\[Kappa]1", "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"\[Mu]", "*", "x"}], "+", 
       RowBox[{"N0", "*", "y", "*", "z"}], "+", 
       RowBox[{"K0", "*", 
        RowBox[{"x", "^", "3"}]}], "+", 
       RowBox[{"K2", "*", "x", "*", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"y", "^", "2"}], "+", 
          RowBox[{"z", "^", "2"}]}], ")"}]}]}], ")"}]}], ",", 
    RowBox[{"\[Kappa]2", "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"\[Mu]", "*", "y"}], "+", 
       RowBox[{"N0", "*", "x", "*", "z"}], "+", 
       RowBox[{"K0", "*", 
        RowBox[{"y", "^", "3"}]}], "+", 
       RowBox[{"K2", "*", "y", "*", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"x", "^", "2"}], "+", 
          RowBox[{"z", "^", "2"}]}], ")"}]}]}], ")"}]}], ",", 
    RowBox[{"\[Kappa]3", "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"\[Mu]", "*", "z"}], "+", 
       RowBox[{"N0", "*", "x", "*", "y"}], "+", 
       RowBox[{"K0", "*", 
        RowBox[{"z", "^", "3"}]}], "+", 
       RowBox[{"K2", "*", "z", "*", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"x", "^", "2"}], "+", 
          RowBox[{"y", "^", "2"}]}], ")"}]}]}], ")"}]}]}], 
   "}"}]}], "\[IndentingNewLine]", 
 RowBox[{"L", "=", 
  RowBox[{
   RowBox[{"{", 
